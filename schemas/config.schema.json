{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Fork Daemon Config",
  "type": "object",
  "required": ["agentfs", "socket_path", "default_profile", "profiles"],
  "properties": {
    "agentfs": { "type": "string" },
    "socket_path": { "type": "string" },
    "default_profile": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]*[A-Za-z0-9])?$" },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "limits"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]*[A-Za-z0-9])?$" },
          "limits": {
            "type": "object",
            "required": ["cpu_max", "memory_max", "pids_max", "disk_max", "network", "idle_timeout", "max_runtime"],
            "properties": {
              "cpu_max": { "type": "string", "pattern": "^(0|[Uu][Nn][Ll][Ii][Mm][Ii][Tt][Ee][Dd]|[Ii][Nn][Ff][Ii][Nn][Ii][Tt][Yy]|[Nn][Oo][Nn][Ee]|[0-9]+(\\.[0-9]+)?%)$" },
              "memory_max": { "type": "string", "pattern": "^(0|[Uu][Nn][Ll][Ii][Mm][Ii][Tt][Ee][Dd]|[Ii][Nn][Ff][Ii][Nn][Ii][Tt][Yy]|[Nn][Oo][Nn][Ee]|[0-9]+(\\.[0-9]+)?([Bb]|[KkMmGgTt][Bb]?))$" },
              "pids_max": { "type": "integer", "minimum": 0 },
              "disk_max": { "type": "string", "pattern": "^(0|[Uu][Nn][Ll][Ii][Mm][Ii][Tt][Ee][Dd]|[Ii][Nn][Ff][Ii][Nn][Ii][Tt][Yy]|[Nn][Oo][Nn][Ee]|[0-9]+(\\.[0-9]+)?([Bb]|[KkMmGgTt][Bb]?))$" },
              "network": { "enum": ["private-nat", "private"] },
              "idle_timeout": { "type": "string", "pattern": "^(0|[Uu][Nn][Ll][Ii][Mm][Ii][Tt][Ee][Dd]|[Ii][Nn][Ff][Ii][Nn][Ii][Tt][Yy]|[Nn][Oo][Nn][Ee]|[0-9]+(\\.[0-9]+)?([Ss]|[Ss][Ee][Cc]|[Mm]|[Mm][Ii][Nn]|[Hh]|[Hh][Rr]|[Dd]|[Dd][Aa][Yy]))$" },
              "max_runtime": { "type": "string", "pattern": "^(0|[Uu][Nn][Ll][Ii][Mm][Ii][Tt][Ee][Dd]|[Ii][Nn][Ff][Ii][Nn][Ii][Tt][Yy]|[Nn][Oo][Nn][Ee]|[0-9]+(\\.[0-9]+)?([Ss]|[Ss][Ee][Cc]|[Mm]|[Mm][Ii][Nn]|[Hh]|[Hh][Rr]|[Dd]|[Dd][Aa][Yy]))$" }
            },
            "additionalProperties": false
          },
          "network_policy": {
            "type": "object",
            "properties": {
              "egress_proxy": { "type": ["string", "null"], "pattern": "^https?://.+" },
              "allowlist": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
