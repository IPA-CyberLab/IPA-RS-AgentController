{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Fork Environment",
  "type": "object",
  "required": ["id", "base_id", "rootfs_path", "machine_name", "state", "profile", "created_at", "limits", "sessions"],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
    "base_id": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
    "rootfs_path": { "type": "string" },
    "machine_name": { "type": "string" },
    "state": { "enum": ["created", "running", "stopped", "failed", "quota_exceeded"] },
    "profile": { "type": "string", "pattern": "^[A-Za-z0-9_-]+$" },
    "created_at": { "type": "string", "format": "date-time" },
    "limits": {
      "type": "object",
      "required": ["cpu_max", "memory_max", "pids_max", "disk_max", "network", "idle_timeout", "max_runtime"],
      "properties": {
        "cpu_max": { "type": "string" },
        "memory_max": { "type": "string" },
        "pids_max": { "type": "integer" },
        "disk_max": { "type": "string" },
        "network": { "enum": ["private-nat", "private"] },
        "idle_timeout": { "type": "string" },
        "max_runtime": { "type": "string" }
      },
      "additionalProperties": false
    },
    "sessions": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
