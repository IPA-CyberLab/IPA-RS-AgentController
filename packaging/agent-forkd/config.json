{
  "agentfs": "/agentfs",
  "socket_path": "/agentfs/runtime/sockets/agent-forkd.sock",
  "default_profile": "privileged-dev",
  "profiles": [
    {
      "name": "privileged-dev",
      "limits": {
        "cpu_max": "400%",
        "memory_max": "16G",
        "pids_max": 4096,
        "disk_max": "100G",
        "network": "private-nat",
        "idle_timeout": "0",
        "max_runtime": "0"
      },
      "network_policy": {
        "egress_proxy": null,
        "allowlist": []
      }
    }
  ]
}
