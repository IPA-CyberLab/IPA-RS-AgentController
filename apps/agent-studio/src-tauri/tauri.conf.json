{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Studio",
  "version": "0.1.0",
  "identifier": "jp.ipa-cyberlab.agent-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Studio",
        "width": 1240,
        "height": 820,
        "minWidth": 940,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"]
  }
}
